{
  "info": {
    "_postman_id": "safeops-collection-1",
    "name": "SafeOps Backend - API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "jobId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"securepassword\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","auth","register"]
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"securepassword\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] }
      }
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh"] }
      }
    },
    {
      "name": "Analysis - Submit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"zoneId\": \"ZONE_3\",\n  \"shiftRiskFactor\": 0.1,\n  \"sensorRawHistory\": [[18.0,28.0,1.2]],\n  \"cvRawFrame\": {\"zone_id\": \"ZONE_3\", \"workers_detected\": 2, \"violations\": []},\n  \"activePermitsRaw\": []\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/analysis/submit", "host": ["{{baseUrl}}"], "path": ["api","v1","analysis","submit"] }
      }
    },
    {
      "name": "Analysis - Status",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/analysis/status/{{jobId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","analysis","status","{{jobId}}"] }
      }
    },
    {
      "name": "Sensor - Anomaly",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"readings\": [[32.0, 29.0, 1.2]]\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/sensor/anomaly", "host": ["{{baseUrl}}"], "path": ["api","v1","sensor","anomaly"] }
      }
    },
    {
      "name": "Permits - Check",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"permits\": [{\"id\": \"P1\", \"zone\": \"ZONE_3\"}],\n  \"currentTime\": \"2026-07-20T12:00:00Z\",\n  \"currentGas\": 0.0\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/permits/check", "host": ["{{baseUrl}}"], "path": ["api","v1","permits","check"] }
      }
    },
    {
      "name": "Simulator - Get Mode",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/simulator/mode", "host": ["{{baseUrl}}"], "path": ["api","v1","simulator","mode"] }
      }
    },
    {
      "name": "Simulator - Update Mode",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"simulationMode\": \"AUTO\",\n  \"zoneId\": \"ZONE_3\",\n  \"shiftRiskFactor\": 0.2\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/simulator/mode", "host": ["{{baseUrl}}"], "path": ["api","v1","simulator","mode"] }
      }
    },
    {
      "name": "Admin - Users",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/admin/users?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","users"], "query": [{"key":"page","value":"0"},{"key":"size","value":"20"}] }
      }
    },
    {
      "name": "Admin - Logs",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/admin/logs?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","logs"], "query": [{"key":"page","value":"0"},{"key":"size","value":"20"}] }
      }
    },
    {
      "name": "Admin - Metrics",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
        "url": { "raw": "{{baseUrl}}/api/v1/admin/metrics", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","metrics"] }
      }
    }
  ]
}

