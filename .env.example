# ─── SafeOps AI Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values

# ─── Gemini AI (Required for live RAG & embeddings) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── PostgreSQL Database ────────────────────────────────────────────
DB_NAME=safeops
DB_USERNAME=safeops
DB_PASSWORD=safeops_secret

# ─── JWT Security ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=dGhpcyBpcyBhIHZlcnkgc2VjcmV0IGtleSBmb3IgSldUIHRva2VucyBpbiBTYWZlT3BzIEFJIGJhY2tlbmQ=

# ─── Spring Profile ─────────────────────────────────────────────────
SPRING_PROFILE=dev
